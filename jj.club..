<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Red Green Predictor Demo</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, sans-serif;
  background: linear-gradient(135deg, #0f172a, #111827, #020617);
  color: white;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.container {
  width: 95%;
  max-width: 420px;
  background: rgba(15, 23, 42, 0.95);
  border-radius: 24px;
  padding: 25px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.45); border:1px solid rgba(255,255,255,0.06);
}

.title {
  text-align: center;
  font-size: 34px; letter-spacing:1px; color:#f8fafc;
  margin-bottom: 20px;
  font-weight: bold;
}

.balance {
  background: linear-gradient(135deg,#1e293b,#0f172a);
  padding: 15px;
  border-radius: 15px;
  text-align: center;
  margin-bottom: 20px;
}

.balance h2 {
  font-size: 18px;
  opacity: 0.8;
}

.balance p {
  font-size: 32px;
  margin-top: 5px;
  color: #22c55e; text-shadow:0 0 10px rgba(34,197,94,0.5);
}

.buttons {
  display: flex;
  gap: 15px;
  margin-bottom: 20px;
}

button {
  flex: 1;
  padding: 16px;
  border: none;
  border-radius: 14px;
  font-size: 20px;
  font-weight: bold;
  cursor: pointer;
  transition: 0.2s;
}

button:hover {
  transform: scale(1.03);
}

.red {
  background: #ff3b3b;
  color: white;
}

.green {
  background: #00c853;
  color: white;
}

.card {
  background: rgba(30,41,59,0.9); border:1px solid rgba(255,255,255,0.05);
  border-radius: 15px;
  padding: 15px;
  margin-top: 15px;
}

.card h3 {
  margin-bottom: 10px;
}

.history {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
}

.dot.redDot {
  background: #ff3b3b;
}

.dot.greenDot {
  background: #00c853;
}

.prediction {
  text-align: center;
  font-size: 28px;
  font-weight: bold;
  margin-top: 10px;
}

.stats {
  display: flex;
  justify-content: space-between;
  margin-top: 10px;
}

.statBox {
  background: rgba(51,65,85,0.9);
  padding: 12px;
  border-radius: 12px;
  width: 48%;
  text-align: center;
}

.footer {
  text-align: center;
  margin-top: 20px;
  opacity: 0.6;
  font-size: 13px;
}
</style>
</head>
<body>

<div class="container">

  <div class="title">👑 Royal Win Predictor</div>

  <div style="text-align:center;margin-bottom:18px;color:#94a3b8;font-size:14px;">
    Premium Demo Gaming Interface
  </div>

  <div class="card">
    <h3>Login Account / Create Account</h3>
    <input type="text" placeholder="Enter Username" style="width:100%;padding:12px;margin-bottom:10px;border:none;border-radius:10px;background:#3a3a3a;color:white;">
    <input type="password" placeholder="Enter Password" style="width:100%;padding:12px;border:none;border-radius:10px;background:#3a3a3a;color:white;">

    <div style="display:flex;gap:10px;margin-top:10px;">
      <button style="background:#2196f3;color:white;">Login</button>
      <button style="background:#9c27b0;color:white;">Register</button>
    </div>
  </div>

  <div class="card">
    <h3>Demo Wallet</h3>
    <p style="text-align:center;opacity:0.7;margin-bottom:10px;">Secure Demo Payment Options</p>

    <div style="display:flex;gap:10px;margin-bottom:12px;">
      <button style="background:#4285F4;color:white;">GPay</button>
      <button style="background:#5f259f;color:white;">PhonePe</button>
      <button style="background:#00b9f1;color:white;">Paytm</button>
    </div>

    <div style="display:flex;gap:10px;">
      <button onclick="fakeDeposit()" style="background:#00c853;color:white;">Demo Deposit</button>
      <button onclick="fakeWithdraw()" style="background:#ff9800;color:white;">Demo Withdrawal</button>
    </div>

    <p id="walletMsg" style="margin-top:10px;text-align:center;"></p>
  </div>

  <div class="balance">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
      <span style="font-size:13px;color:#94a3b8;">VIP LEVEL 3</span>
      <span style="background:#22c55e;padding:4px 10px;border-radius:20px;font-size:12px;">ONLINE</span>
    </div>
    <h2>Royal Coins</h2>
    <p id="coins">1000</p>
  </div>

  <div class="buttons">
    <button class="red" onclick="addColor('R')">WHITE</button>
    <button class="green" onclick="addColor('G')">BLACK</button>
  </div>

  <div class="card">
    <h3>Prediction</h3>
    <div class="prediction" id="prediction">-</div>
  </div>

  <div class="card">
    <h3>History</h3>
    <div class="history" id="history"></div>
  </div>

  <div class="card">
    <h3>Stats</h3>

    <div class="stats">
      <div class="statBox">
        <h4>Red</h4>
        <p id="redCount">0</p>
      </div>

      <div class="statBox">
        <h4>Green</h4>
        <p id="greenCount">0</p>
      </div>
    </div>
  </div>

  <div class="card">
    <h3>Big Small Predictor</h3>
    <div class="prediction" id="bigSmallPrediction">BIG</div>
  </div>

  <div class="card">
    <h3>Sky Aviator</h3>
    <div style="text-align:center;font-size:34px;font-weight:bold;" id="aviator">1.00x</div>
    <button onclick="startAviator()" style="margin-top:10px;background:#ff1744;color:white;">Start Aviator</button>
  </div>

  <div class="card">
    <h3>Chicken Road Adventure</h3>
    <div id="road" style="display:flex;gap:8px;justify-content:center;margin-top:10px;"></div>
    <button onclick="playRoad()" style="margin-top:10px;background:#ffc107;color:black;">Play</button>
  </div>

  <div style="margin-top:20px;background:linear-gradient(135deg,#7c3aed,#2563eb);padding:18px;border-radius:18px;text-align:center;">
    <h3 style="margin-bottom:8px;">🎁 Daily Bonus</h3>
    <p style="opacity:0.9;font-size:14px;">Claim your free demo rewards every day</p>
    <button style="margin-top:12px;background:white;color:black;font-weight:bold;">Claim Bonus</button>
  </div>

  <div class="footer">
    Royal Win Demo Platform © 2026
  </div>

</div>

<script>
let history = [];
let coins = 1000;

function addColor(color) {
  history.push(color);

  updateHistory();
  updateStats();
  predictNext();

  coins += 10;
  document.getElementById('coins').innerText = coins;
}

function updateHistory() {
  let historyDiv = document.getElementById('history');
  historyDiv.innerHTML = '';

  history.slice(-12).forEach(c => {
    let dot = document.createElement('div');
    dot.classList.add('dot');

    if(c === 'R') {
      dot.classList.add('redDot');
    } else {
      dot.classList.add('greenDot');
    }

    historyDiv.appendChild(dot);
  });
}

function updateStats() {
  let red = history.filter(x => x === 'R').length;
  let green = history.filter(x => x === 'G').length;

  document.getElementById('redCount').innerText = red;
  document.getElementById('greenCount').innerText = green;
}

function predictNext() {
  let prediction = 'R';

  if(history.length >= 3) {
    let last3 = history.slice(-3);

    if(last3.every(x => x === 'R')) {
      prediction = 'G';
    }
    else if(last3.every(x => x === 'G')) {
      prediction = 'R';
    }
    else {
      let red = history.filter(x => x === 'R').length;
      let green = history.filter(x => x === 'G').length;

      prediction = red > green ? 'R' : 'G';
    }
  }

  let text = prediction === 'R' ? 'WHITE' : 'BLACK';
  let color = prediction === 'R' ? '#ff3b3b' : '#00c853';

  let pred = document.getElementById('prediction');
  pred.innerText = text;
  pred.style.color = color;
}
function fakeDeposit() {
  coins += 500;
  document.getElementById('coins').innerText = coins;
  document.getElementById('walletMsg').innerText = 'Demo Deposit Successful via GPay / PhonePe / Paytm';
}

function fakeWithdraw() {
  if(coins >= 200) {
    coins -= 200;
    document.getElementById('coins').innerText = coins;
    document.getElementById('walletMsg').innerText = 'Demo Withdrawal Successful via GPay / PhonePe / Paytm';
  } else {
    document.getElementById('walletMsg').innerText = 'Not Enough Demo Coins';
  }
}

function startAviator() {
  let value = 1;
  let aviator = document.getElementById('aviator');

  let interval = setInterval(() => {
    value += 0.12;
    aviator.innerText = value.toFixed(2) + 'x';

    if(value >= (Math.random() * 5 + 2)) {
      clearInterval(interval);
      aviator.innerText += ' CRASH';
    }
  }, 120);
}

function playRoad() {
  let road = document.getElementById('road');
  road.innerHTML = '';

  for(let i=0;i<6;i++) {
    let box = document.createElement('div');
    box.style.width = '45px';
    box.style.height = '45px';
    box.style.borderRadius = '10px';

    if(Math.random() > 0.5) {
      box.style.background = '#00c853';
    } else {
      box.style.background = '#ff3b3b';
    }

    road.appendChild(box);
  }
}

function updateBigSmall() {
  let text = Math.random() > 0.5 ? 'BIG' : 'SMALL';
  document.getElementById('bigSmallPrediction').innerText = text;
}

setInterval(updateBigSmall, 3000);

</script>

</body>
</html>
